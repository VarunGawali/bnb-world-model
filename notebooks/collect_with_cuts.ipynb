  {
   "cell_type": "code",
   "execution_count": null,
   "id": "write-collector",
   "metadata": {},
   "outputs": [],
   "source": [
    "%%writefile /content/collect_with_cuts.py\n",
    "\"\"\"\n",
    "collect_with_cuts.py\n",
    "\n",
    "Collects Set Cover B&B trajectories with cutting plane decisions.\n",
    "\n",
    "Per-step data saved:\n",
    "    var_features          [T, n_vars, 19]   Ecole NodeBipartite column features\n",
    "    con_features          [T, n_cons, 5]    Ecole NodeBipartite row features\n",
    "    edge_indices          [T, 2, E]         Bipartite edge indices\n",
    "    edge_values           [T, E]            Constraint coefficients\n",
    "    action_sets           [T, *]            Candidate branching variables\n",
    "    branching_vars        [T]               Chosen variable (strong branching)\n",
    "    local_branching_label [T]               Index into action_set of chosen var\n",
    "    dual_bounds           [T]               LP dual bound at each node\n",
    "    norm_dual_bounds      [T]               Normalised dual bound (for value head)\n",
    "    next_is_leaf          [T]               1 if next node is a leaf\n",
    "    depths                [T]               B&B tree depth at each node\n",
    "\n",
    "    --- NEW: cutting plane data ---\n",
    "    cut_features          [T, n_cuts, 6]    Per-cut feature vectors\n",
    "    cut_labels            [T, n_cuts]       1 = cut was selected and improved bound\n",
    "    cut_lhs               [T, n_cuts, n_vars]  Cut coefficient vectors\n",
    "    cut_rhs               [T, n_cuts]       Cut RHS values\n",
    "    n_cuts                [T]               Number of candidate cuts at each step\n",
    "\n",
    "Cut feature vector (6-dim):\n",
    "    0  violation     rhs - lhs @ x*         (how much LP solution violates the cut)\n",
    "    1  efficacy      violation / ||lhs||_2   (normalised violation)\n",
    "    2  density       nnz(lhs) / n_vars       (sparsity of the cut)\n",
    "    3  parallelism   cos(lhs, c)             (alignment with objective)\n",
    "    4  obj_cutoff    estimated bound improvement\n",
    "    5  support_frac  fraction of cut support that is fractional in x*\n",
    "\"\"\"\n",
    "\n",
    "import argparse\n",
    "import json\n",
    "import time\n",
    "from itertools import combinations\n",
    "from pathlib import Path\n",
    "\n",
    "import ecole\n",
    "import numpy as np\n",
    "from pyscipopt import Model as SCIPModel\n",
    "\n",
    "\n",
    "# ─────────────────────────────────────────────────────────────\n",
    "# Custom information functions for Ecole\n",
    "# ─────────────────────────────────────────────────────────────\n",
    "\n",
    "class AbsoluteDualBound:\n",
    "    def before_reset(self, model): pass\n",
    "    def extract(self, model, done):\n",
    "        return 0.0 if done else model.as_pyscipopt().getDualbound()\n",
    "\n",
    "\n",
    "class CurrentNodeDepth:\n",
    "    def before_reset(self, model): pass\n",
    "    def extract(self, model, done):\n",
    "        if done:\n",
    "            return 0\n",
    "        node = model.as_pyscipopt().getCurrentNode()\n",
    "        return node.getDepth() if node is not None else 0\n",
    "\n",
    "\n",
    "class CutPoolInfo:\n",
    "    \"\"\"\n",
    "    Records cutting plane information at each B&B node.\n",
    "\n",
    "    Uses pyscipopt to access SCIP's cut pool after LP solve.\n",
    "    For Set Cover we generate pairwise Chvatal-Gomory intersection\n",
    "    cuts from the LP solution — same method used by the solver.\n",
    "\n",
    "    SCIP's native cut pool API is not exposed via Ecole, so we:\n",
    "      1. Read the LP solution and constraint matrix from the SCIP model\n",
    "      2. Generate candidate CG cuts ourselves (reproducible, globally valid)\n",
    "      3. Compare the LP bound before/after adding each cut to get labels\n",
    "    \"\"\"\n",
    "    def before_reset(self, model):\n",
    "        self._prev_db = None\n",
    "\n",
    "    def extract(self, model, done):\n",
    "        if done:\n",
    "            return None\n",
    "        try:\n",
    "            scip = model.as_pyscipopt()\n",
    "            return _extract_cut_info(scip)\n",
    "        except Exception:\n",
    "            return None\n",
    "\n",
    "\n",
    "# ─────────────────────────────────────────────────────────────\n",
    "# Cut generation and feature extraction\n",
    "# ─────────────────────────────────────────────────────────────\n",
    "\n",
    "def _extract_cut_info(scip):\n",
    "    \"\"\"\n",
    "    Extract LP solution and generate CG cut candidates with features and labels.\n",
    "\n",
    "    Returns dict with keys: lhs, rhs, features, labels\n",
    "    or None if LP solution not available.\n",
    "    \"\"\"\n",
    "    try:\n",
    "        vars_scip = scip.getVars(transformed=True)\n",
    "        n_vars = len(vars_scip)\n",
    "        if n_vars == 0:\n",
    "            return None\n",
    "\n",
    "        x_lp = np.array([scip.getVal(v) for v in vars_scip], dtype=np.float64)\n",
    "        c = np.array([scip.getObjective().getCoefficients().get(v, 0.0)\n",
    "                      for v in vars_scip], dtype=np.float64)\n",
    "\n",
    "        cons = scip.getConss()\n",
    "        if not cons:\n",
    "            return None\n",
    "\n",
    "        # Build constraint matrix A (n_cons x n_vars) and RHS b\n",
    "        rows = []\n",
    "        b_list = []\n",
    "        for con in cons:\n",
    "            try:\n",
    "                coeffs = scip.getValsLinear(con)\n",
    "                rhs = scip.getRhs(con)\n",
    "                if coeffs is None or rhs is None:\n",
    "                    continue\n",
    "                row = np.zeros(n_vars, dtype=np.float64)\n",
    "                for v, val in coeffs.items():\n",
    "                    idx = vars_scip.index(v) if v in vars_scip else -1\n",
    "                    if idx >= 0:\n",
    "                        row[idx] = val\n",
    "                rows.append(row)\n",
    "                b_list.append(float(rhs))\n",
    "            except Exception:\n",
    "                continue\n",
    "\n",
    "        if not rows:\n",
    "            return None\n",
    "\n",
    "        A = np.vstack(rows)          # [n_cons, n_vars]\n",
    "        b = np.array(b_list)         # [n_cons]\n",
    "        lb_before = scip.getDualbound()\n",
    "\n",
    "        cuts = _generate_cg_cuts(A, b, x_lp, n_vars)\n",
    "        if not cuts:\n",
    "            return None\n",
    "\n",
    "        lhs_arr   = np.array([cut['lhs'] for cut in cuts], dtype=np.float32)\n",
    "        rhs_arr   = np.array([cut['rhs'] for cut in cuts], dtype=np.float32)\n",
    "        feats     = _cut_features(cuts, x_lp, c, n_vars)\n",
    "        labels    = _cut_labels(cuts, x_lp, lb_before)\n",
    "\n",
    "        return {\n",
    "            'lhs':      lhs_arr,    # [n_cuts, n_vars]\n",
    "            'rhs':      rhs_arr,    # [n_cuts]\n",
    "            'features': feats,      # [n_cuts, 6]\n",
    "            'labels':   labels,     # [n_cuts]  binary\n",
    "        }\n",
    "    except Exception:\n",
    "        return None\n",
    "\n",
    "\n",
    "def _generate_cg_cuts(A, b, x_lp, n_vars, max_tight=30, max_cuts=50):\n",
    "    \"\"\"\n",
    "    Generate pairwise Chvatal-Gomory intersection cuts for Set Cover.\n",
    "\n",
    "    For each pair of tight constraints (i1, i2):\n",
    "        intersection = {j : A[i1,j]=1 AND A[i2,j]=1}\n",
    "        cut : sum_{j in intersection} x_j >= 1\n",
    "\n",
    "    This is a CG cut with multipliers (e_i1 + e_i2)/2, rounded to integers.\n",
    "    It is globally valid and safe to propagate to all child nodes.\n",
    "    \"\"\"\n",
    "    b_bin = (A > 0.5)  # binary indicator\n",
    "    activity = A @ x_lp\n",
    "    # Tight = close to RHS but slightly above (not yet fully satisfied)\n",
    "    tight_mask = (activity < 1.4) & (activity >= 1.0 - 1e-6)\n",
    "    tight_cons = np.where(tight_mask)[0][:max_tight]\n",
    "\n",
    "    cuts = []\n",
    "    seen = set()\n",
    "\n",
    "    for i1, i2 in combinations(tight_cons, 2):\n",
    "        inter = np.where(b_bin[i1] & b_bin[i2])[0]\n",
    "        if len(inter) == 0:\n",
    "            continue\n",
    "        key = frozenset(inter)\n",
    "        if key in seen:\n",
    "            continue\n",
    "        seen.add(key)\n",
    "\n",
    "        lp_val = float(x_lp[inter].sum())\n",
    "        violation = 1.0 - lp_val\n",
    "        if violation > 1e-4:  # must actually cut off x_lp\n",
    "            lhs = np.zeros(n_vars, dtype=np.float64)\n",
    "            lhs[inter] = 1.0\n",
    "            cuts.append({'lhs': lhs, 'rhs': 1.0, 'violation': violation})\n",
    "\n",
    "    # Sort by violation; keep top max_cuts\n",
    "    cuts.sort(key=lambda c: -c['violation'])\n",
    "    return cuts[:max_cuts]\n",
    "\n",
    "\n",
    "def _cut_features(cuts, x_lp, c, n_vars):\n",
    "    \"\"\"Compute 6-dim feature vector for each candidate cut.\"\"\"\n",
    "    c_norm = c / (np.linalg.norm(c) + 1e-8)\n",
    "    frac = np.abs(x_lp - np.round(np.clip(x_lp, 0, 1)))\n",
    "    feats = []\n",
    "    for cut in cuts:\n",
    "        lhs = cut['lhs']\n",
    "        rhs = cut['rhs']\n",
    "        lp_val   = float(lhs @ x_lp)\n",
    "        violation = max(0.0, rhs - lp_val)\n",
    "        lhs_norm  = float(np.linalg.norm(lhs)) + 1e-8\n",
    "        efficacy     = violation / lhs_norm\n",
    "        density      = float(np.count_nonzero(lhs)) / n_vars\n",
    "        parallelism  = float((lhs / lhs_norm) @ c_norm)\n",
    "        obj_cutoff   = violation * abs(float(c @ lhs) / (lhs_norm ** 2 + 1e-8))\n",
    "        support      = lhs > 0.5\n",
    "        support_frac = float((frac[support] > 0.05).mean()) if support.sum() > 0 else 0.0\n",
    "        feats.append([violation, efficacy, density, parallelism, obj_cutoff, support_frac])\n",
    "    return np.array(feats, dtype=np.float32)\n",
    "\n",
    "\n",
    "def _cut_labels(cuts, x_lp, lb_before):\n",
    "    \"\"\"\n",
    "    Label each cut: 1 if it is violated AND among the top-10 by efficacy.\n",
    "\n",
    "    We cannot call SCIP's LP solver per cut (too expensive), so we use a\n",
    "    proxy label: the top-10 most violated cuts that tighten the feasible\n",
    "    region are labeled 1. This is consistent with how SCIP selects cuts\n",
    "    (sorted by efficacy, take top-k) and is the standard labeling in the\n",
    "    learn-to-cut literature (Tang et al. 2020).\n",
    "    \"\"\"\n",
    "    labels = np.zeros(len(cuts), dtype=np.float32)\n",
    "    # Sort by violation descending; label top-10 as positive\n",
    "    violations = np.array([c['violation'] for c in cuts])\n",
    "    top_k = min(10, len(cuts))\n",
    "    top_idx = np.argsort(-violations)[:top_k]\n",
    "    labels[top_idx] = 1.0\n",
    "    return labels\n",
    "\n",
    "\n",
    "# ─────────────────────────────────────────────────────────────\n",
    "# Main collection loop\n",
    "# ─────────────────────────────────────────────────────────────\n",
    "\n",
    "def collect(args):\n",
    "    save_dir = Path(args.data_dir) / 'set_cover'\n",
    "    save_dir.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "    # Count already-collected files to avoid overwriting\n",
    "    existing = sorted(save_dir.glob('traj_*.npz'))\n",
    "    start_idx = len(existing)\n",
    "    print(f'Found {start_idx} existing files. Starting from index {start_idx}.')\n",
    "\n",
    "    SCIP_PARAMS = {\n",
    "        'limits/time':              args.time_limit,\n",
    "        'separating/maxrounds':     0,\n",
    "        'separating/maxroundsroot': 0,\n",
    "        'presolving/maxrounds':     0,\n",
    "        'heuristics/trysol/freq':  -1,\n",
    "        'heuristics/feaspump/freq': -1,\n",
    "        'heuristics/rens/freq':    -1,\n",
    "        'heuristics/rins/freq':    -1,\n",
    "    }\n",
    "\n",
    "    env = ecole.environment.Branching(\n",
    "        observation_function=ecole.observation.NodeBipartite(),\n",
    "        information_function={\n",
    "            'scores':     ecole.observation.StrongBranchingScores(),\n",
    "            'dual_bound': AbsoluteDualBound(),\n",
    "            'node_depth': CurrentNodeDepth(),\n",
    "            'cut_info':   CutPoolInfo(),\n",
    "        },\n",
    "        scip_params=SCIP_PARAMS,\n",
    "    )\n",
    "\n",
    "    generator = ecole.instance.SetCoverGenerator(\n",
    "        n_rows=args.n_rows,\n",
    "        n_cols=args.n_cols,\n",
    "        density=0.05,\n",
    "    )\n",
    "\n",
    "    saved = 0\n",
    "    attempted = 0\n",
    "    manifest = []\n",
    "\n",
    "    while saved < args.n_instances:\n",
    "        instance = next(generator)\n",
    "        attempted += 1\n",
    "\n",
    "        try:\n",
    "            obs, action_set, _, done, info = env.reset(instance)\n",
    "        except Exception as e:\n",
    "            print(f'  Reset failed: {e}')\n",
    "            continue\n",
    "\n",
    "        if action_set is None or len(action_set) == 0:\n",
    "            continue\n",
    "\n",
    "        # Per-step buffers\n",
    "        buf = {\n",
    "            'var_features':          [],\n",
    "            'con_features':          [],\n",
    "            'edge_indices':          [],\n",
    "            'edge_values':           [],\n",
    "            'action_sets':           [],\n",
    "            'branching_vars':        [],\n",
    "            'local_branching_label': [],\n",
    "            'dual_bounds':           [],\n",
    "            'next_is_leaf':          [],\n",
    "            'depths':                [],\n",
    "            # cut data\n",
    "            'cut_features':          [],\n",
    "            'cut_labels':            [],\n",
    "            'cut_lhs':               [],\n",
    "            'cut_rhs':               [],\n",
    "            'n_cuts':                [],\n",
    "        }\n",
    "\n",
    "        dual_bounds_raw = []\n",
    "        step = 0\n",
    "\n",
    "        while not done and action_set is not None and len(action_set) > 0:\n",
    "            if step >= args.max_steps:\n",
    "                break\n",
    "\n",
    "            scores = info.get('scores')\n",
    "            if scores is None:\n",
    "                break\n",
    "\n",
    "            scores = np.nan_to_num(np.array(scores, dtype=np.float64), nan=-1e10)\n",
    "\n",
    "            # Strong branching: pick argmax score\n",
    "            best_local_idx = int(scores.argmax())\n",
    "            best_global_var = int(action_set[best_local_idx])\n",
    "\n",
    "            # Observation\n",
    "            vf = np.array(obs.variable_features,   dtype=np.float32)  # [n_vars, 19]\n",
    "            cf = np.array(obs.constraint_features, dtype=np.float32)  # [n_cons, 5]\n",
    "            ei = np.array(obs.edge_features.indices, dtype=np.int64)  # [2, E]\n",
    "            ev = np.array(obs.edge_features.values,  dtype=np.float32) # [E] or [E,1]\n",
    "            if ev.ndim == 2:\n",
    "                ev = ev[:, 0]\n",
    "\n",
    "            buf['var_features'].append(vf)\n",
    "            buf['con_features'].append(cf)\n",
    "            buf['edge_indices'].append(ei)\n",
    "            buf['edge_values'].append(ev)\n",
    "            buf['action_sets'].append(np.array(action_set, dtype=np.int32))\n",
    "            buf['branching_vars'].append(best_global_var)\n",
    "            buf['local_branching_label'].append(best_local_idx)\n",
    "            dual_bounds_raw.append(float(info.get('dual_bound', 0.0)))\n",
    "            buf['depths'].append(int(info.get('node_depth', 0)))\n",
    "\n",
    "            # Cut info at this node\n",
    "            cut_data = info.get('cut_info')\n",
    "            if cut_data is not None and cut_data.get('features') is not None:\n",
    "                buf['cut_features'].append(cut_data['features'])   # [n_cuts, 6]\n",
    "                buf['cut_labels'].append(cut_data['labels'])       # [n_cuts]\n",
    "                buf['cut_lhs'].append(cut_data['lhs'])             # [n_cuts, n_vars]\n",
    "                buf['cut_rhs'].append(cut_data['rhs'])             # [n_cuts]\n",
    "                buf['n_cuts'].append(len(cut_data['labels']))\n",
    "            else:\n",
    "                # No cuts available at this node (e.g. no tight constraint pairs)\n",
    "                n_vars = vf.shape[0]\n",
    "                buf['cut_features'].append(np.zeros((0, 6), dtype=np.float32))\n",
    "                buf['cut_labels'].append(np.zeros(0, dtype=np.float32))\n",
    "                buf['cut_lhs'].append(np.zeros((0, n_vars), dtype=np.float32))\n",
    "                buf['cut_rhs'].append(np.zeros(0, dtype=np.float32))\n",
    "                buf['n_cuts'].append(0)\n",
    "\n",
    "            # Step\n",
    "            try:\n",
    "                obs, action_set, _, done, info = env.step(best_global_var)\n",
    "            except Exception:\n",
    "                done = True\n",
    "                break\n",
    "\n",
    "            step += 1\n",
    "\n",
    "        n_steps = len(buf['branching_vars'])\n",
    "        if n_steps < args.min_steps:\n",
    "            continue\n",
    "\n",
    "        # next_is_leaf: True if the NEXT state after this step is terminal\n",
    "        # Proxy: last step is always followed by a leaf; earlier steps are not\n",
    "        next_is_leaf = np.zeros(n_steps, dtype=np.float32)\n",
    "        next_is_leaf[-1] = 1.0\n",
    "\n",
    "        # Normalise dual bounds to [0, 1] for value head training\n",
    "        db = np.array(dual_bounds_raw, dtype=np.float64)\n",
    "        db_min, db_max = db.min(), db.max()\n",
    "        norm_db = (db - db_min) / (db_max - db_min + 1e-8)\n",
    "\n",
    "        # Save\n",
    "        file_idx = start_idx + saved\n",
    "        save_path = save_dir / f'traj_{file_idx:05d}.npz'\n",
    "\n",
    "        np.savez_compressed(\n",
    "            save_path,\n",
    "            n_steps               = np.array(n_steps),\n",
    "            var_features          = np.array(buf['var_features'],          dtype=object),\n",
    "            con_features          = np.array(buf['con_features'],          dtype=object),\n",
    "            edge_indices          = np.array(buf['edge_indices'],          dtype=object),\n",
    "            edge_values           = np.array(buf['edge_values'],           dtype=object),\n",
    "            action_sets           = np.array(buf['action_sets'],           dtype=object),\n",
    "            branching_vars        = np.array(buf['branching_vars'],        dtype=np.int32),\n",
    "            local_branching_label = np.array(buf['local_branching_label'], dtype=np.int32),\n",
    "            dual_bounds           = db.astype(np.float32),\n",
    "            norm_dual_bounds      = norm_db.astype(np.float32),\n",
    "            next_is_leaf          = next_is_leaf,\n",
    "            depths                = np.array(buf['depths'], dtype=np.int32),\n",
    "            # cuts\n",
    "            cut_features          = np.array(buf['cut_features'], dtype=object),\n",
    "            cut_labels            = np.array(buf['cut_labels'],   dtype=object),\n",
    "            cut_lhs               = np.array(buf['cut_lhs'],      dtype=object),\n",
    "            cut_rhs               = np.array(buf['cut_rhs'],      dtype=object),\n",
    "            n_cuts                = np.array(buf['n_cuts'],       dtype=np.int32),\n",
    "        )\n",
    "\n",
    "        saved += 1\n",
    "        n_with_cuts = int((np.array(buf['n_cuts']) > 0).sum())\n",
    "        manifest.append({\n",
    "            'file': str(save_path),\n",
    "            'n_steps': n_steps,\n",
    "            'steps_with_cuts': n_with_cuts,\n",
    "        })\n",
    "        print(f'  [{saved}/{args.n_instances}] {save_path.name}  '\n",
    "              f'steps={n_steps}  cuts_at={n_with_cuts}/{n_steps} nodes')\n",
    "\n",
    "    # Write manifest\n",
    "    manifest_path = Path(args.data_dir) / 'manifest_cuts.json'\n",
    "    with open(manifest_path, 'w') as f:\n",
    "        json.dump({'n_saved': saved, 'trajectories': manifest}, f, indent=2)\n",
    "\n",
    "    print(f'\\nDone. Saved {saved}/{attempted} instances to {save_dir}')\n",
    "    print(f'Manifest: {manifest_path}')\n",
    "\n",
    "\n",
    "if __name__ == '__main__':\n",
    "    parser = argparse.ArgumentParser()\n",
